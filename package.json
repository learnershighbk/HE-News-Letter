{
  "name": "kdis-news-curator",
  "version": "1.0.0",
  "description": "KDI School 고등교육/AI 뉴스 자동 큐레이션 서비스",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "pipeline": "tsx src/pipeline.ts"
  },
  "keywords": [
    "news",
    "curation",
    "higher-education",
    "ai",
    "newsletter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@notionhq/client": "^5.16.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "p-limit": "^6.2.0",
    "rss-parser": "^3.13.0",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  }
}
